# Copy this file to .env.local and fill in the values.
# These are passed as --build-arg to Docker (baked at build time).

# URL of the Fleet Gateway (used by Vite proxy — NOT bundled into client code)
# - Local dev (gateway running on same machine): omit or set to http://127.0.0.1:8080
# - Remote robot:  GATEWAY_URL=http://10.61.6.87:8080
# GATEWAY_URL=http://10.61.6.87:8080

# URL of the Supabase/Kong API gateway
# - Local dev:    http://localhost:8000
# - On robot:     http://10.61.6.87:8000  (replace with actual robot IP)
VITE_SUPABASE_URL=http://localhost:8000

# Supabase anonymous JWT — get this from your .env / Supabase Studio
VITE_SUPABASE_ANON_KEY=
